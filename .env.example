# ========== AI 挑战赛 - 环境变量配置 ==========
# 复制此文件为 .env 并修改以下配置

# 服务端口
PORT=3000

# 后台初始密码（首次登录后会强制修改）
# 修改后此值不再生效，密码存储在数据库中
ADMIN_PASSWORD=admin123

# 参赛组数（默认10组）
GROUP_COUNT=10

# ========== AI 接口配置 ==========
# AI API 配置已移至后台管理面板
# 启动服务后访问 http://localhost:3000/admin → 系统设置 → AI接口配置
# 默认使用阿里百炼（DashScope），需要在后台填入你的 API Key
# 获取 API Key：https://bailian.console.aliyun.com/
