# ========== AI 挑战赛 - 环境变量配置 ==========
# 复制此文件为 .env 并修改以下配置

# 服务端口
PORT=3000

# 后台管理密码（请修改为你自己的密码）
ADMIN_PASSWORD=xiangjin1215

# Gemini API 配置（通过 OpenAI 兼容代理）
API_BASE_URL=https://api.kegeai.top
API_KEY=你的API密钥
AI_MODEL=gemini-2.5-flash-image-preview
AI_MODEL_FALLBACK=gemini-3.1-flash-image-preview

# 参赛组数（默认10组）
GROUP_COUNT=10
